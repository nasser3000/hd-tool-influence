<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Confirmation Häagen-Dazs</title>
</head>
<body style="margin:0;padding:0;background-color:#F5E8D8;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;">

  <!-- Wrapper -->
  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#F5E8D8;padding:40px 20px;">
    <tr>
      <td align="center">
        <table width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:600px;width:100%;">

          <!-- HEADER -->
          <tr>
            <td style="background:#6B1A38;border-radius:24px 24px 0 0;padding:40px 48px 36px;text-align:center;">
              <!-- Logo circle -->
              <div style="display:inline-block;background:#FDF5ED;border-radius:50%;width:72px;height:72px;line-height:72px;text-align:center;margin-bottom:20px;">
                <span style="font-size:32px;">🍦</span>
              </div>
              <p style="margin:0 0 4px;font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,0.5);">Häagen-Dazs</p>
              <h1 style="margin:0;font-size:32px;font-weight:900;color:#FDF5ED;line-height:1.2;">Proposition de<br>collaboration</h1>
            </td>
          </tr>

          <!-- WAVE SEPARATOR (burgundy to cream) -->
          <tr>
            <td style="background:#6B1A38;padding:0;">
              <div style="background:#FDF5ED;height:0;">
                <svg viewBox="0 0 600 40" xmlns="http://www.w3.org/2000/svg" style="display:block;width:100%;height:40px;" preserveAspectRatio="none">
                  <path d="M0,0 C150,40 450,40 600,0 L600,40 L0,40 Z" fill="#6B1A38"/>
                </svg>
              </div>
            </td>
          </tr>

          <!-- GREETING -->
          <tr>
            <td style="background:#FDF5ED;padding:40px 48px 20px;text-align:center;">
              <p style="margin:0;font-size:18px;font-weight:800;color:#6B1A38;">Bonjour <%= @participation.first_name %> ! 👋</p>
              <p style="margin:12px 0 0;font-size:15px;line-height:1.7;color:#6B4C3B;">Ta participation à notre programme influenceurs est confirmée.<br>Voici ton bon d'accès à présenter en boutique.</p>
            </td>
          </tr>

          <!-- BON / VOUCHER CARD -->
          <tr>
            <td style="background:#FDF5ED;padding:20px 48px 32px;">
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#FFFFFF;border-radius:20px;overflow:hidden;box-shadow:0 4px 24px rgba(107,26,56,0.12);">
                <!-- Voucher header -->
                <tr>
                  <td style="background:#6B1A38;padding:24px 32px;text-align:center;">
                    <p style="margin:0;font-size:10px;font-weight:800;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,0.5);">Bon de participation</p>
                    <p style="margin:8px 0 0;font-size:22px;font-weight:900;color:#FDF5ED;">🍦 <%= @store.city %></p>
                    <p style="margin:4px 0 0;font-size:13px;color:rgba(255,255,255,0.65);"><%= @store.name %></p>
                  </td>
                </tr>

                <!-- Dashed border separator -->
                <tr>
                  <td style="padding:0 32px;">
                    <div style="border-top:2px dashed #F5E8D8;margin:0;"></div>
                  </td>
                </tr>

                <!-- Voucher info rows -->
                <tr>
                  <td style="padding:28px 32px;">
                    <!-- Holder -->
                    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:16px;">
                      <tr>
                        <td style="font-size:10px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;color:#A0826D;padding-bottom:4px;">Titulaire</td>
                      </tr>
                      <tr>
                        <td style="font-size:18px;font-weight:900;color:#2C1810;"><%= @participation.first_name %> <%= @participation.last_name %></td>
                        <td align="right" style="font-size:14px;font-weight:700;color:#6B1A38;"><%= @participation.instagram_handle %></td>
                      </tr>
                    </table>

                    <!-- Divider -->
                    <div style="border-top:1px solid #F5E8D8;margin:16px 0;"></div>

                    <!-- Address -->
                    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:16px;">
                      <tr>
                        <td style="font-size:10px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;color:#A0826D;padding-bottom:4px;">Boutique</td>
                      </tr>
                      <tr>
                        <td style="font-size:14px;font-weight:700;color:#2C1810;">📍 <%= @store.address %></td>
                      </tr>
                    </table>

                    <!-- Divider -->
                    <div style="border-top:1px solid #F5E8D8;margin:16px 0;"></div>

                    <!-- Offer -->
                    <table width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="font-size:10px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;color:#A0826D;padding-bottom:4px;">Ton offre exclusive</td>
                      </tr>
                      <tr>
                        <td>
                          <div style="background:#FDF5ED;border-left:3px solid #C9954C;border-radius:0 10px 10px 0;padding:14px 16px;font-size:14px;line-height:1.6;color:#2C1810;font-weight:600;">
                            <%= @store.offer %>
                          </div>
                        </td>
                      </tr>
                    </table>

                    <!-- Period -->
                    <div style="border-top:1px solid #F5E8D8;margin:20px 0 16px;"></div>
                    <table width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="font-size:10px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;color:#A0826D;padding-bottom:4px;">Période de validité</td>
                      </tr>
                      <tr>
                        <td style="font-size:14px;font-weight:700;color:#2C1810;">📅 Juillet à mi-septembre 2025</td>
                      </tr>
                    </table>
                  </td>
                </tr>

                <!-- Token / Reference -->
                <tr>
                  <td style="background:#F5E8D8;padding:16px 32px;text-align:center;border-radius:0 0 20px 20px;">
                    <p style="margin:0;font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:#A0826D;">Référence</p>
                    <p style="margin:4px 0 0;font-size:12px;font-family:monospace;font-weight:700;color:#6B1A38;letter-spacing:2px;"><%= @participation.token %></p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- WHAT TO DO SECTION -->
          <tr>
            <td style="background:#FDF5ED;padding:0 48px 32px;">
              <p style="margin:0 0 20px;font-size:13px;font-weight:800;letter-spacing:1px;text-transform:uppercase;color:#6B1A38;">Ce qu'on attend de toi :</p>

              <table width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="width:40px;vertical-align:top;padding-top:2px;font-size:22px;">📸</td>
                  <td style="padding-bottom:16px;">
                    <p style="margin:0;font-size:14px;font-weight:700;color:#2C1810;">Partage ton expérience</p>
                    <p style="margin:4px 0 0;font-size:13px;line-height:1.5;color:#6B4C3B;">1 story et/ou 1 réel sur ton compte Instagram en taguant <strong>@haagendazs_fr</strong></p>
                  </td>
                </tr>
                <tr>
                  <td style="width:40px;vertical-align:top;padding-top:2px;font-size:22px;">👥</td>
                  <td style="padding-bottom:16px;">
                    <p style="margin:0;font-size:14px;font-weight:700;color:#2C1810;">Viens avec un +1</p>
                    <p style="margin:4px 0 0;font-size:13px;line-height:1.5;color:#6B4C3B;">Amène un ami ou un proche pour tester notre nouvelle carte d'été ensemble.</p>
                  </td>
                </tr>
                <tr>
                  <td style="width:40px;vertical-align:top;padding-top:2px;font-size:22px;">🎟️</td>
                  <td>
                    <p style="margin:0;font-size:14px;font-weight:700;color:#2C1810;">Présente ce bon</p>
                    <p style="margin:4px 0 0;font-size:13px;line-height:1.5;color:#6B4C3B;">Montre cet email à l'équipe en boutique lors de ton arrivée.</p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- FOOTER STRIP -->
          <tr>
            <td style="background:#6B1A38;border-radius:0 0 24px 24px;padding:28px 48px;text-align:center;">
              <p style="margin:0;font-size:13px;color:rgba(255,255,255,0.7);line-height:1.6;">Des questions ? Réponds directement à cet email.<br>On a hâte de te voir ! ✨</p>
              <p style="margin:16px 0 0;font-size:10px;color:rgba(255,255,255,0.35);letter-spacing:1px;text-transform:uppercase;">Häagen-Dazs — Programme Influenceurs Été 2025</p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>

</body>
</html>
