<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Nouvelle inscription influenceur</title>
</head>
<body style="margin:0;padding:0;background:#F5E8D8;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#F5E8D8;padding:32px 20px;">
    <tr>
      <td align="center">
        <table width="540" cellpadding="0" cellspacing="0" border="0" style="max-width:540px;width:100%;background:#FFFFFF;border-radius:20px;overflow:hidden;box-shadow:0 4px 24px rgba(107,26,56,0.12);">

          <tr>
            <td style="background:#6B1A38;padding:28px 36px;">
              <p style="margin:0;font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,0.5);">Häagen-Dazs — Notification admin</p>
              <h1 style="margin:8px 0 0;font-size:22px;font-weight:900;color:#FDF5ED;">Nouvelle inscription 🍦</h1>
            </td>
          </tr>

          <tr>
            <td style="padding:32px 36px;">
              <table width="100%" cellpadding="0" cellspacing="0" border="0">

                <tr>
                  <td style="padding-bottom:20px;border-bottom:1px solid #F5E8D8;">
                    <p style="margin:0 0 4px;font-size:10px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;color:#A0826D;">Influenceur</p>
                    <p style="margin:0;font-size:18px;font-weight:900;color:#2C1810;"><%= @participation.first_name %> <%= @participation.last_name %></p>
                    <p style="margin:4px 0 0;font-size:14px;font-weight:700;color:#6B1A38;"><%= @participation.instagram_handle %></p>
                    <p style="margin:4px 0 0;font-size:13px;color:#6B4C3B;"><%= @participation.email %></p>
                  </td>
                </tr>

                <tr>
                  <td style="padding:20px 0;border-bottom:1px solid #F5E8D8;">
                    <p style="margin:0 0 4px;font-size:10px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;color:#A0826D;">Boutique choisie</p>
                    <p style="margin:0;font-size:16px;font-weight:900;color:#2C1810;"><%= @store.name %></p>
                    <p style="margin:4px 0 0;font-size:13px;color:#6B4C3B;">📍 <%= @store.address %></p>
                  </td>
                </tr>

                <tr>
                  <td style="padding:20px 0;border-bottom:1px solid #F5E8D8;">
                    <p style="margin:0 0 4px;font-size:10px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;color:#A0826D;">Offre confirmée</p>
                    <p style="margin:0;font-size:13px;line-height:1.6;color:#2C1810;"><%= @store.offer.gsub("\n", " · ") %></p>
                  </td>
                </tr>

                <tr>
                  <td style="padding-top:20px;">
                    <p style="margin:0 0 4px;font-size:10px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;color:#A0826D;">Inscrit le</p>
                    <p style="margin:0;font-size:13px;color:#2C1810;"><%= @participation.created_at.strftime("%d/%m/%Y à %H:%M") %></p>
                    <p style="margin:8px 0 0;font-size:11px;font-family:monospace;color:#A0826D;">Ref : <%= @participation.token %></p>
                  </td>
                </tr>

              </table>
            </td>
          </tr>

          <tr>
            <td style="background:#F5E8D8;padding:16px 36px;text-align:center;">
              <p style="margin:0;font-size:11px;color:#A0826D;">Häagen-Dazs — Programme Influenceurs Été 2026</p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
